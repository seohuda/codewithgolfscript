# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase Service Role Key (NEVER expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Piston public execution API
PISTON_API_URL=https://emkc.org/api/v2/execute

# Session signing secret (long random string)
SESSION_SECRET=your-long-random-secret

# Public base URL used in email links (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.golfscript.xyz

# Resend (email verification + password reset)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=CODE WITH GOLFSCRIPT <no-reply@golfscript.xyz>

