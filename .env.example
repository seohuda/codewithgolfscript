# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase Service Role Key (NEVER expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Piston public execution API
PISTON_API_URL=https://emkc.org/api/v2/execute

# Session signing secret (long random string)
SESSION_SECRET=your-long-random-secret

# Public base URL used in email links (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-app.amplifyapp.com

# AWS SES (email verification + password reset)
# Note: SES_* prefix avoids clashing with Lambda's reserved AWS_* vars.
SES_REGION=ap-northeast-2
SES_ACCESS_KEY_ID=your-access-key-id
SES_SECRET_ACCESS_KEY=your-secret-access-key
SES_FROM_EMAIL=no-reply@yourdomain.com

